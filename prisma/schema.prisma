// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int    @id @default(autoincrement())
  name            String
  email           String
  password        String 
  appointments    Appointment[]
}

model Profissinal {
  id              Int   @id @default(autoincrement())
  nome            String
  email           String
  password        String  
  especialidade   String
  bio             String  
  horario         DateTime
  appointments    Appointment[]
}

model Appointment {
  id              Int   @id @default(autoincrement())
  date            DateTime
  description     String
  status          String

  userId          Int
  user            User        @relation(fields: [userId], references: [id])

  professionalId  Int
  professional    Profissinal @relation(fields: [professionalId], references: [id])
}